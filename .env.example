# Browser-safe values only. Never put a secret/service-role key in NEXT_PUBLIC_*.
# Railway production should set both values to https://slidexdeck.com. These
# local defaults keep OAuth callbacks on the port used by `npm run dev`.
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Project Settings -> API. The publishable key establishes product
# identity only; it is not an OpenAI model key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Server-only HMAC key for Remote MCP OAuth endpoint rate-limit buckets.
# Use at least 32 random bytes and never expose it through NEXT_PUBLIC_*.
MCP_OAUTH_RATE_LIMIT_SECRET=replace-with-at-least-32-random-bytes

# Independent server-only HMAC key for deidentifying OAuth security events.
# Use at least 32 random bytes. Never reuse or expose this through NEXT_PUBLIC_*.
MCP_OAUTH_AUDIT_HMAC_SECRET=replace-with-a-different-32-byte-random-value

# Conversational agent rollout. The editor and agent server flags must both be
# enabled, and changing NEXT_PUBLIC_* values requires rebuilding the editor.
NEXT_PUBLIC_SLIDEX_AGENT_ENABLED=false
NEXT_PUBLIC_SLIDEX_AGENT_SERVER_URL=http://localhost:3010

# Users enter their own OpenAI API key in the Agent panel. There is deliberately
# no model-key environment variable: the key stays in current-tab React memory
# and is sent only with a run-start request.
