# Conversational agent rollout. The editor and agent server flags must both be
# enabled, and changing NEXT_PUBLIC_* values requires rebuilding the editor.
NEXT_PUBLIC_SLIDEX_AGENT_ENABLED=false
NEXT_PUBLIC_SLIDEX_AGENT_SERVER_URL=http://localhost:3010

# Product identity only. Enable anonymous sign-ins in the matching Supabase
# project's Auth settings. This public anon key is not an OpenAI model key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Users enter their own OpenAI API key in the Agent panel. There is deliberately
# no model-key environment variable: the key stays in current-tab React memory
# and is sent only with a run-start request.
