{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SlideX",
  "version": "2.0.1",
  "identifier": "app.slidex.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev:no-clean",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SlideX",
        "url": "/studio/",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "files": {
        "Resources/slidex-project.icns": "icons/slidex-project.icns"
      },
      "infoPlist": "Info.plist"
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
