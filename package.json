{
  "name": "slidex",
  "version": "2.0.4",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); for (const p of ['.next','.next-turbo','tsconfig.tsbuildinfo']) fs.rmSync(p,{recursive:true,force:true})\"",
    "dev": "npm run clean && (ulimit -n 1048575 || true) && WATCHPACK_POLLING=true NEXT_DIST_DIR=.next-turbo next dev --turbopack",
    "dev:no-clean": "(ulimit -n 1048575 || true) && WATCHPACK_POLLING=true NEXT_DIST_DIR=.next-turbo next dev --turbopack",
    "dev:reset": "npm run dev",
    "build": "next build --webpack",
    "build:clean": "npm run clean && npm run build",
    "start": "next start",
    "test": "tsx --test common/lib/*.test.ts core/motion-doc/application/*.test.ts core/motion-doc/infrastructure/export/*.test.ts features/auth/application/*.test.ts features/pitch/application/*.test.ts features/pitch/infrastructure/*.test.ts features/workspace/application/*.test.ts features/workspace/infrastructure/*.test.ts",
    "lint": "eslint .",
    "mcp": "tsx mcp/server.ts",
    "mcp:build": "node scripts/build-mcp-server.mjs",
    "mcp:pack": "npm pack ./packages/slidex-mcp-server",
    "mcp:publish": "npm publish ./packages/slidex-mcp-server --access public",
    "test:agent": "esbuild features/pitch/infrastructure/slidexAgentProtocol.test.mts --bundle --platform=node --format=esm --outfile=.next/agent-protocol-test.mjs && node --test .next/agent-protocol-test.mjs",
    "test:agent:e2e": "playwright test",
    "test:agent:e2e:install": "playwright install chromium",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:types": "supabase gen types typescript --local --schema public"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@paper-design/shaders": "^0.0.77",
    "@paper-design/shaders-react": "^0.0.77",
    "@radix-ui/react-alert-dialog": "1.1.19",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-toolbar": "^1.1.13",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@roackb2/heddle-remote": "5.0.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "@tanstack/react-query": "^5.101.2",
    "@tiptap/extension-bubble-menu": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@uiw/react-codemirror": "^4.25.10",
    "border-beam": "^1.2.0",
    "dayjs": "^1.11.21",
    "framer-motion": "11.18.2",
    "geist": "^1.7.2",
    "html2canvas-pro": "^2.2.3",
    "lucide-react": "^1.16.0",
    "next": "16.2.10",
    "next-themes": "0.4.6",
    "pptxgenjs": "^4.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.184.1",
    "@webgpu/types": "^0.1.70",
    "esbuild": "^0.28.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-boundaries": "^6.0.2",
    "postcss": "8.5.14",
    "supabase": "^2.109.1",
    "tailwindcss": "4.3.0",
    "tsx": "^4.22.4",
    "typescript": "5.9.3"
  },
  "description": "SlideX Pitch is a focused presentation workspace with a precise canvas, solid fills, and editable motion.",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zz41354899/Animark.git"
  },
