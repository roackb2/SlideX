{
  "name": "slidex",
  "version": "2.0.4",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); for (const p of ['.next','.next-turbo','tsconfig.tsbuildinfo']) fs.rmSync(p,{recursive:true,force:true})\"",
    "dev": "npm run clean && (ulimit -n 1048575 || true) && WATCHPACK_POLLING=true NEXT_DIST_DIR=.next-turbo next dev --turbopack",
    "dev:no-clean": "(ulimit -n 1048575 || true) && WATCHPACK_POLLING=true NEXT_DIST_DIR=.next-turbo next dev --turbopack",
    "dev:reset": "npm run dev",
    "build": "next build --webpack",
    "build:clean": "npm run clean && npm run build",
    "start": "next start",
    "lint": "eslint .",
    "mcp": "tsx mcp/server.ts",
    "mcp:build": "node scripts/build-mcp-server.mjs",
    "mcp:pack": "npm pack ./packages/slidex-mcp-server",
    "mcp:publish": "npm publish ./packages/slidex-mcp-server --access public",
    "briefly:mcp": "tsx mcp/brieflyServer.ts",
    "briefly:mcp:build": "node scripts/build-briefly-mcp-server.mjs",
    "briefly:mcp:pack": "npm pack ./packages/briefly-mcp-server",
    "briefly:mcp:publish": "npm publish ./packages/briefly-mcp-server --access public"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-toolbar": "^1.1.13",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@tiptap/extension-bubble-menu": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@uiw/react-codemirror": "^4.25.10",
    "@z7589xxz758/briefly-mcp-server": "^0.1.0",
    "border-beam": "^1.2.0",
    "framer-motion": "11.18.2",
    "geist": "^1.7.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.184.1",
    "@webgpu/types": "^0.1.70",
    "esbuild": "^0.28.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-boundaries": "^6.0.2",
    "postcss": "8.5.14",
    "tailwindcss": "4.3.0",
    "tsx": "^4.22.4",
    "typescript": "5.9.3"
  },
  "description": "SlideX 是一個以 MDX Slide 為核心的動態簡報系統。它把簡報內容、版面、動畫節奏、預覽與桌面專案流程放在同一個可維護的程式碼結構裡。全新升級的 Pitch 介面採用 Double-Bezel 玻璃擬真（Glassmorphism）與高對比視覺美學，將開發工具的穩健與高階設計的質感完美融合。",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zz41354899/Animark.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/zz41354899/Animark/issues"
  },
  "homepage": "https://github.com/zz41354899/Animark#readme"
}
