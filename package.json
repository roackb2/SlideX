{
  "name": "slidex",
  "version": "2.0.4",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); for (const p of ['.next','.next-turbo','tsconfig.tsbuildinfo']) fs.rmSync(p,{recursive:true,force:true})\"",
    "dev": "npm run clean && (ulimit -n 1048575 || true) && WATCHPACK_POLLING=true NEXT_DIST_DIR=.next-turbo next dev --turbopack",
    "dev:no-clean": "(ulimit -n 1048575 || true) && WATCHPACK_POLLING=true NEXT_DIST_DIR=.next-turbo next dev --turbopack",
    "dev:reset": "npm run dev",
    "build": "next build --webpack",
    "build:clean": "npm run clean && npm run build",
    "start": "next start",
    "lint": "eslint .",
    "icons:tauri": "node scripts/generate-tauri-icons.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@tauri-apps/api": "^2.11.0",
    "@uiw/react-codemirror": "^4.25.10",
    "framer-motion": "11.18.2",
    "geist": "^1.7.2",
    "lucide-react": "1.16.0",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@tailwindcss/postcss": "4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.184.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-boundaries": "^6.0.2",
    "postcss": "8.5.14",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3"
  }
}
